---
import SEO from '@/components/SEO.astro';
import type { SEOProps } from '@/data/seo';
import { HTML_LANG } from '@/data/locale';

import '@/styles/global.css';

type Props = SEOProps;

const seoProps = Astro.props;
---

<!doctype html>
<html lang={HTML_LANG}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fira+Sans:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap"
    />

    <SEO {...seoProps} />

    <!-- Cloudflare Turnstile — used by newsletter + contact forms -->
    <script
      is:inline
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer></script>
  </head>
  <body>
    <slot />

    <script>
      import { initializeScrollSystem } from '@/lib/scroll';
      import { initParallax, initReveals } from '@/lib/parallax';

      initializeScrollSystem().then(() => {
        initParallax();
        initReveals();
      });
    </script>
  </body>
</html>
