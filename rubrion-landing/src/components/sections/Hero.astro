---
import { SITE_TAGLINE } from '@/data/seo';
import { heroSteps } from '@/data/heroSteps';
---

<section
  id="hero"
  class="min-h-svh flex items-center justify-center px-4 pt-24 pb-16"
>
  <div class="w-full max-w-4xl mx-auto text-center reveal-group">
    <div class="reveal flex justify-center mb-8">
      <img
        src="/logo_rubrion_ver4.svg"
        alt="Rubrion logo"
        width="112"
        height="112"
        loading="eager"
        decoding="async"
        class="w-24 h-24 md:w-28 md:h-28"
      />
    </div>

    <h1 class="reveal text-5xl md:text-7xl font-bold text-heading mb-6">
      {SITE_TAGLINE}
    </h1>

    <p class="reveal text-lg md:text-2xl font-mono text-text mb-10 max-w-2xl mx-auto">
      &gt; IT consulting + whitelabel for SMBs<br />
      &gt; Complex software, cheap to deliver, transparent to operate
    </p>

    <div class="reveal flex flex-col sm:flex-row gap-4 justify-center mb-16">
      <a
        href="#contact"
        class="nav-anchor btn btn--accent px-8 py-4 text-lg whitespace-nowrap"
      >
        &gt;talk_to_us
      </a>
      <a
        href="#projects"
        class="nav-anchor btn btn--ghost px-8 py-4 text-lg whitespace-nowrap"
      >
        &gt;see_projects
      </a>
    </div>

    <aside aria-label="Platform principles">
      <ul class="grid sm:grid-cols-3 gap-4 text-left reveal-group">
        {
          heroSteps.map((step) => (
            <li class="reveal panel panel--accent p-5">
              <h2 class="text-base font-semibold text-heading mb-1">
                {step.title}
              </h2>
              <p class="text-sm text-muted">{step.description}</p>
            </li>
          ))
        }
      </ul>
    </aside>
  </div>
</section>
