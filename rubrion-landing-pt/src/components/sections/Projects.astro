---
import Icon from '@/components/Icon.astro';
import { PROJECTS } from '@/data/projects';
---

<section id="projects" class="py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="reveal text-4xl md:text-5xl text-heading mb-4">Projetos</h2>
      <p class="reveal text-lg text-muted max-w-2xl mx-auto">
        O que entregamos — sites ao vivo e código aberto.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 reveal-group">
      {
        PROJECTS.map((project) => (
          <article class="reveal panel p-6 flex flex-col">
            <div class="flex items-start justify-between mb-4">
              <div class="w-10 h-10 bg-header-bg border-2 border-ink rounded-lg flex items-center justify-center text-accent">
                <Icon name={project.iconName} class="w-5 h-5" />
              </div>
              {project.isSister && (
                <span
                  class="font-mono text-[10px] uppercase tracking-wider text-muted border border-border px-2 py-1 rounded"
                  aria-label="Projeto irmão"
                >
                  Projeto irmão
                </span>
              )}
            </div>

            <span class="font-mono text-xs text-muted mb-2">
              {project.category}
            </span>
            <h3 class="text-2xl text-heading mb-3">{project.title}</h3>
            <p class="text-text mb-5 flex-grow">{project.description}</p>

            <ul class="flex flex-wrap gap-2 mb-6" aria-label="Tags">
              {project.tags.map((tag) => (
                <li class="font-mono text-[11px] text-muted bg-header-bg border border-border rounded px-2 py-1">
                  {tag}
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-3 mt-auto">
              <a
                href={project.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--accent inline-flex items-center gap-2 px-4 py-2 text-sm"
              >
                <Icon name="ExternalLink" class="w-4 h-4" strokeWidth={2} />
                &gt;visitar_site
              </a>
              {project.repoUrl && (
                <a
                  href={project.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-muted hover:text-heading px-4 py-2 rounded font-mono text-sm transition-colors"
                >
                  <Icon name="Github" class="w-4 h-4" strokeWidth={2} />
                  &gt;ver_codigo
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
