---
import Icon from '@/components/Icon.astro';
import { segments } from '@/data/segments';
---

<section id="who-we-serve" class="py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="reveal text-4xl md:text-5xl text-heading mb-4">Quem Atendemos</h2>
      <p class="reveal text-lg text-muted max-w-2xl mx-auto">
        PMEs, startups, escolas, ONGs, empresas.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 reveal-group">
      {
        segments.map((segment) => (
          <article class="reveal panel p-8">
            <div class="mb-4 text-accent">
              <Icon name={segment.iconName} class="w-8 h-8" />
            </div>
            <h3 class="text-2xl text-heading mb-3">{segment.title}</h3>
            <p class="text-text mb-6">{segment.description}</p>
            <ul class="space-y-2">
              {segment.features.map((feature) => (
                <li class="flex items-center text-muted text-sm">
                  <span class="w-1.5 h-1.5 bg-accent rounded-full mr-3" />
                  {feature}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
