---
import { SITE_NAME, SUPPORT_EMAIL } from '@/data/seo';

const year = new Date().getFullYear();
---

<footer class="relative z-10 border-t border-border bg-header-bg py-10 px-4">
  <div
    class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-muted"
  >
    <div class="flex items-center gap-3">
      <img
        src="/logo_rubrion_ver4.svg"
        width="28"
        height="28"
        alt={SITE_NAME}
        class="h-7 w-7"
      />
      <address class="not-italic">
        <span class="text-heading font-bold">{SITE_NAME}</span> ·
        <a href={`mailto:${SUPPORT_EMAIL}`} class="text-accent hover:underline"
          >{SUPPORT_EMAIL}</a
        >
      </address>
    </div>

    <nav aria-label="Rodapé">
      <ul class="flex flex-wrap gap-x-6 gap-y-2">
        <li>
          <a href="/#who-we-serve" class="hover:text-heading transition-colors"
            >Quem Atendemos</a
          >
        </li>
        <li>
          <a href="/#projects" class="hover:text-heading transition-colors"
            >Projetos</a
          >
        </li>
        <li>
          <a href="/blog" class="hover:text-heading transition-colors">Blog</a>
        </li>
        <li>
          <a href="/#contact" class="hover:text-heading transition-colors"
            >Contato</a
          >
        </li>
      </ul>
    </nav>

    <p>© {year} {SITE_NAME}. Code-free, cloud-fee.</p>
  </div>
</footer>
